    "usage": {
        "message": "Usage"
    },
    "usage_overview_title": {
        "message": "Overview"
    },
    "usage_overview_body": {
        "message": "Proxy Helper switches Chrome's proxy independently of the system proxy. Each profile holds a complete proxy configuration. Click a profile in the popup to activate it."
    },
    "usage_profiles_title": {
        "message": "Profiles"
    },
    "usage_profiles_body": {
        "message": "Create one profile per environment (Work, Home, Travel). Use the bar at the top of this page: + New to create, Rename / Duplicate / Delete to manage, Set Active to apply the selected profile to Chrome."
    },
    "usage_modes_title": {
        "message": "Active Mode"
    },
    "usage_modes_body": {
        "message": "Every profile has its own Active Mode — the proxy type Chrome uses when the profile is selected. The Active Mode tab shows only modes you have configured. Direct, System, and Auto Detect (WPAD) are always available."
    },
    "usage_servers_title": {
        "message": "Server Configuration"
    },
    "usage_servers_body": {
        "message": "Enter proxy host and port for HTTP, HTTPS, or SOCKS in the General tab. For SOCKS, pick the protocol version (SOCKS4 or SOCKS5). Proxy Mode controls how Chrome routes requests across proxies (singleProxy uses one proxy for all traffic)."
    },
    "usage_pac_title": {
        "message": "PAC (Proxy Auto-Config)"
    },
    "usage_pac_body": {
        "message": "PAC scripts decide the proxy per URL. Paste a script inline under PAC Script, or point to a hosted script under PAC URL."
    },
    "usage_bypass_title": {
        "message": "Bypass List"
    },
    "usage_bypass_body": {
        "message": "Domains and IP ranges that should not use the proxy. Separate entries with commas. Example: <local>, 192.168.0.0/16, *.intranet.com. Enable China List to also bypass *.cn domains."
    },
    "usage_auth_title": {
        "message": "Authentication"
    },
    "usage_auth_body": {
        "message": "Username and password for proxies that require basic authentication. Note: Chrome's API supports authentication for HTTP/HTTPS proxies only, not SOCKS."
    },
    "usage_shortcuts_title": {
        "message": "Keyboard Shortcuts"
    },
    "usage_shortcuts_body": {
        "message": "Alt+P cycles to the next profile. Alt+O opens this options page. Customize the shortcuts at chrome://extensions/shortcuts."
    },
    "usage_switching_title": {
        "message": "Switching Profiles"
    },
    "usage_switching_body": {
        "message": "Click the toolbar icon to open the popup, then click any profile to activate it. The profile's Active Mode is applied to Chrome immediately."
    }
}
